# 🍮Chat v2.0 配置（本地方案，零外部依赖）

# ── LLM（必填）──
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-deepseek-key
OPENAI_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60

# ── JWT（可选，默认自动生成）──
# JWT_SECRET=your-secret-key
# JWT_EXPIRE_HOURS=168

# ── 微信（可选）──
# WX_APP_ID=your-wx-app-id
# WX_APP_SECRET=your-wx-app-secret
# WX_REDIRECT_URI=http://localhost:8000/api/auth/wechat/callback
# WX_TOKEN=your-wx-token
